# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_max
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
INTERNAL_API_SECRET=change_me_internal_api_secret_min_16
JWT_EXPIRES_IN=7d

# Public site URL (ссылки для клиентов)
PUBLIC_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Имена ботов для deep-link (без @)
TELEGRAM_BOT_USERNAME=your_telegram_bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Только имя из ссылки max.ru/ИМЯ (не полный URL)
MAX_BOT_USERNAME=id451005642528_1_bot

# URL сервисов ботов (для уведомлений и рассылки)
MAX_BOT_URL=http://localhost:3001
TELEGRAM_BOT_URL=http://localhost:3002

# Яндекс.Карты: подсказки адреса, геокодирование, карта на странице клиента
# https://developer.tech.yandex.ru/ — ключ с доступом «JavaScript API и HTTP Геокодер»
# В настройках ключа укажите ограничение по Referer: woner.ru, localhost
YANDEX_MAPS_API_KEY=

# Биллинг ЮKassa (BILLING_ENABLED=false — бесплатный режим, раздел «Оплата» на замке)
BILLING_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:5173/dashboard?section=billing
# Чеки 54-ФЗ: 1=ОСН, 2=УСН доход, 3=УСН доход-расход, 6=патент
# Для ИП на НПД (самозанятый) tax_system_code не передавайте — оставьте пустым.
# YOOKASSA_TAX_SYSTEM_CODE=2
# 1=без НДС
YOOKASSA_VAT_CODE=1
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# BILLING_FROM_EMAIL=

# SEO: Яндекс.Вебмастер API (позиции, показы, клики в админ-панели)
# OAuth-токен: https://yandex.ru/dev/webmaster/doc/dg-v3/concepts/access.html
SITE_URL=https://woner.ru
# YANDEX_WEBMASTER_OAUTH_TOKEN=
# YANDEX_WEBMASTER_HOST_URL=https://woner.ru
# YANDEX_WEBMASTER_USER_ID=
# YANDEX_WEBMASTER_HOST_ID=

# IndexNow — уведомление Яндекса и других ПС об изменениях на сайте
# Ключ: 8–128 символов a-z A-Z 0-9 -. Файл: https://woner.ru/{ключ}.txt
# INDEXNOW_KEY=your_indexnow_key_here

# SEO: Google Search Console (service account с доступом к сайту)
# GSC_SERVICE_ACCOUNT_EMAIL=
# GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GSC_SITE_URL=https://woner.ru/
