# API-only image. Frontend is NOT baked in — mount ./frontend/dist on the host:
#   ./frontend/dist:/app/frontend/dist:ro
# Build UI: cd frontend && npm run build  (or deploy/sync-live.sh)
FROM node:18-alpine
WORKDIR /app

COPY backend/package*.json ./
RUN npm install --omit=dev

COPY backend/ ./
RUN mkdir -p /app/frontend/dist /app/uploads

EXPOSE 3000
CMD ["node", "src/server.js"]
