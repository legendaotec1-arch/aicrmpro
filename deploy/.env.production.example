# === Домен woner.ru ===
DOMAIN=woner.ru
PUBLIC_URL=https://woner.ru
FRONTEND_URL=https://woner.ru

# SSL снаружи (Beget/nginx) → docker-compose.prod-external-ssl.yml
# SSL в Docker с вашими .pem → Caddyfile.custom-cert + docker-compose.prod.yml

# === База (в Docker оставьте postgres, иначе — внешний Beget) ===
DB_HOST=postgres
DB_PORT=5432
DB_NAME=crm_max
DB_USER=postgres
DB_PASSWORD=ЗАМЕНИТЕ_СИЛЬНЫЙ_ПАРОЛЬ

# === Безопасность ===
JWT_SECRET=ЗАМЕНИТЕ_ДЛИННЫЙ_СЛУЧАЙНЫЙ_КЛЮЧ

# === MAX бот ===
MAX_BOT_TOKEN=
MAX_WEBHOOK_URL=https://ваш-домен.ru/webhook
MAX_WEBHOOK_SECRET=
MAX_API_URL=https://platform-api.max.ru
MAX_BOT_USERNAME=имя_бота_в_max

# === Telegram бот ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=имя_бота_без_собаки

# Внутри Docker менять не нужно
BACKEND_URL=http://backend:3000
MAX_BOT_URL=http://bot:3001
TELEGRAM_BOT_URL=http://telegram-bot:3002
