# Готовый шаблон для woner.ru (SSL на домене)
DOMAIN=woner.ru
PUBLIC_URL=https://woner.ru
FRONTEND_URL=https://woner.ru

# Для авто-настройки nginx + Let's Encrypt при deploy (install-server.sh)
LETSENCRYPT_EMAIL=your@email.ru

# Если SSL на Beget/хостинге, а Docker на VPS — используйте compose:
# docker compose -f docker-compose.prod-external-ssl.yml up -d
BACKEND_PORT=3000
BOT_PORT=3001
TELEGRAM_BOT_PORT=3002

DB_HOST=postgres
DB_PORT=5432
DB_NAME=crm_max
DB_USER=postgres
DB_PASSWORD=ЗАМЕНИТЕ

JWT_SECRET=ЗАМЕНИТЕ_ДЛИННЫЙ_КЛЮЧ
INTERNAL_API_SECRET=ЗАМЕНИТЕ_СЛУЧАЙНЫЙ_КЛЮЧ_16_СИМВОЛОВ

MAX_BOT_TOKEN=
MAX_API_URL=https://platform-api.max.ru
MAX_BOT_USERNAME=
# Webhook MAX (HTTPS): https://ваш-домен.ru/webhook
MAX_WEBHOOK_URL=
MAX_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

BACKEND_URL=http://backend:3000
MAX_BOT_URL=http://bot:3001
TELEGRAM_BOT_URL=http://telegram-bot:3002

# Биллинг ЮKassa
BILLING_ENABLED=true
BILLING_PER_BOOKING_FEE=20
BILLING_UNLIMITED_PRICE=900
BILLING_UNLIMITED_DAYS=30
BILLING_MIN_TOPUP=100
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://woner.ru/dashboard?section=billing
# Webhook в кабинете ЮKassa: https://ваш-домен.ru/api/billing/yookassa/webhook
#
# Деплой UI (не docker cp в контейнер!):
#   /opt/aicrmpro/deploy/sync-live.sh
# Backend отдаёт ./frontend/dist с диска через volume mount.
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# BILLING_FROM_EMAIL=

# Push владельцу (Telegram/MAX user ID) — настраивается и в кабинете «Настройки»
# NOTIFY_TELEGRAM_USER_ID=
# NOTIFY_MAX_USER_ID=

# Яндекс.Карты (подсказки адреса + карта с меткой на странице записи)
YANDEX_MAPS_API_KEY=

# GitHub (push с сервера; не коммитить реальный .env)
GITHUB_USERNAME=legendaotec1-arch
GITHUB_REPO=aicrmpro
GITHUB_TOKEN=
