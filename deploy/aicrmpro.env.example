# Готовый шаблон для masterclient45.ru (SSL уже на домене)

DOMAIN=masterclient45.ru
PUBLIC_URL=https://masterclient45.ru
FRONTEND_URL=https://masterclient45.ru

# Для авто-настройки nginx + Let's Encrypt при deploy (install-server.sh)
LETSENCRYPT_EMAIL=your@email.ru

# Если SSL на Beget/хостинге, а Docker на VPS — используйте compose:
# docker compose -f docker-compose.prod-external-ssl.yml up -d
BACKEND_PORT=3000
BOT_PORT=3001
TELEGRAM_BOT_PORT=3002

DB_HOST=postgres
DB_PORT=5432
DB_NAME=crm_max
DB_USER=postgres
DB_PASSWORD=ЗАМЕНИТЕ

JWT_SECRET=ЗАМЕНИТЕ_ДЛИННЫЙ_КЛЮЧ

MAX_BOT_TOKEN=
MAX_API_URL=https://platform-api.max.ru
MAX_BOT_USERNAME=
# Webhook MAX (HTTPS): https://ваш-домен.ru/webhook
MAX_WEBHOOK_URL=
MAX_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

BACKEND_URL=http://backend:3000
MAX_BOT_URL=http://bot:3001
TELEGRAM_BOT_URL=http://telegram-bot:3002

# Биллинг ЮKassa (BILLING_ENABLED=false — сервис бесплатный, раздел «Оплата» на замке)
BILLING_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://masterclient45.ru/dashboard?section=billing
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# BILLING_FROM_EMAIL=

# Push владельцу (Telegram/MAX user ID) — настраивается и в кабинете «Настройки»
# NOTIFY_TELEGRAM_USER_ID=
# NOTIFY_MAX_USER_ID=

# Яндекс.Карты (подсказки адреса + карта с меткой на странице записи)
YANDEX_MAPS_API_KEY=

# GitHub (push с сервера; не коммитить реальный .env)
GITHUB_USERNAME=legendaotec1-arch
GITHUB_REPO=aicrmpro
GITHUB_TOKEN=
